# VITE_GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in your repository secrets as GEMINI_API_KEY; the GitHub Actions
# workflow maps it to VITE_GEMINI_API_KEY at build time so Vite can expose it
# to the client bundle. For local development, set it directly here.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
VITE_APP_URL="MY_APP_URL"

# VITE_SYNC_API_URL: URL of the pool sync server API.
# Leave empty (or omit) during local development — Vite proxies /api/* to
# localhost:3001 automatically.  In production, set this to the full URL of
# your deployed sync server (e.g. "https://your-server.example.com").
# VITE_SYNC_API_URL=""
