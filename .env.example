# VITE_GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in your repository secrets as GEMINI_API_KEY; the GitHub Actions
# workflow maps it to VITE_GEMINI_API_KEY at build time so Vite can expose it
# to the client bundle. For local development, set it directly here.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
VITE_APP_URL="MY_APP_URL"

# ─── Firebase configuration ───────────────────────────────────────────────
# Copy these values from your Firebase project console:
#   Firebase Console → Project settings → Your apps → Web app → SDK setup
#
# These keys are safe to include in client-side code — Firebase security is
# enforced by Firestore Security Rules in the Firebase console.
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="MY_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_PROJECT_ID.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_APP_ID"
