# Vertex AI / Gemini API configuration
#
# VITE_GOOGLE_GENAI_USE_VERTEXAI: Set to "True" to route AI requests through the
# Vertex AI API endpoint instead of the standard Gemini API endpoint.
# In browser runtimes the @google/genai SDK requires an API key for auth (set in
# VITE_GOOGLE_CREDENTIALS_JSON or VITE_GEMINI_API_KEY below).
VITE_GOOGLE_GENAI_USE_VERTEXAI="True"

# VITE_GOOGLE_CLOUD_PROJECT: Your Google Cloud project ID.
# Used for Vertex AI service configuration (Node.js/server-side only).
VITE_GOOGLE_CLOUD_PROJECT="YOUR_GCP_PROJECT_ID"

# VITE_GOOGLE_CLOUD_LOCATION: Google Cloud region for Vertex AI.
# Use "global" for the global endpoint or a specific region (e.g. "us-central1").
VITE_GOOGLE_CLOUD_LOCATION="global"

# VITE_GOOGLE_CREDENTIALS_JSON: Credentials for Vertex AI authentication.
# For browser-based Vertex AI access, provide a Google Cloud API key string with
# the Vertex AI API enabled on your project.
# A service-account JSON is accepted here for server-side/Node.js use, but is NOT
# usable directly in browser runtimes — use a plain API key in that case.
# Set this in your repository secrets as GOOGLE_CREDENTIALS_JSON; the GitHub
# Actions workflow maps it to VITE_GOOGLE_CREDENTIALS_JSON at build time.
VITE_GOOGLE_CREDENTIALS_JSON="YOUR_VERTEX_AI_API_KEY_OR_CREDENTIALS_JSON"

# VITE_GEMINI_API_KEY: Fallback API key for the standard Gemini API endpoint.
# Only required when VITE_GOOGLE_GENAI_USE_VERTEXAI is not set or if
# VITE_GOOGLE_CREDENTIALS_JSON is not a usable API key in browser context.
# Set this in your repository secrets as GEMINI_API_KEY.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
VITE_APP_URL="MY_APP_URL"

# Firebase configuration is hardcoded in src/lib/firebase.ts.
# Firebase client config values are public and safe to commit — security is
# enforced by Firestore Security Rules in the Firebase console.
