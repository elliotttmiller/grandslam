rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pool documents — readable and writable by any signed-in user, including
    // users who were automatically signed in anonymously on first load.
    //
    // The app always calls signInAnonymously() before touching Firestore, so
    // every real user satisfies request.auth != null.  The rule blocks raw
    // HTTP requests that don't carry a Firebase auth token (abuse prevention).
    match /pools/{poolId} {
      allow read, write: if request.auth != null;
    }

  }
}
