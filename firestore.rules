rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(resourceData) {
      return isSignedIn() && resourceData.ownerId == request.auth.uid;
    }

    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data)
        || (
          isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberIds', 'updatedAt'])
          && request.resource.data.members is list
          && resource.data.members is list
          && request.resource.data.memberIds is list
          && resource.data.memberIds is list
          && request.resource.data.members.size() >= resource.data.members.size()
          && request.resource.data.memberIds.size() >= resource.data.memberIds.size()
        );
      allow delete: if isOwner(resource.data);
    }

    match /pools/{poolId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data)
        || (
          isSignedIn()
          && request.resource.data.keys().hasOnly(['entries', 'participantIds', 'updatedAt'])
          && request.resource.data.entries is list
          && resource.data.entries is list
          && request.resource.data.entries.size() >= resource.data.entries.size()
          && request.resource.data.participantIds is list
          && resource.data.participantIds is list
          && request.resource.data.participantIds.size() >= resource.data.participantIds.size()
        );
      allow delete: if isOwner(resource.data);
    }

    match /tournaments/{tournamentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data);
      allow delete: if isOwner(resource.data);
    }

    match /system/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.requestedBy == request.auth.uid
        && request.resource.data.requestedBy == request.auth.uid;
    }
  }
}
