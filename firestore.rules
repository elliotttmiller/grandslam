rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pool documents — readable and writable only by users who have created a
    // named Firebase account (email/password or social provider).  Anonymous
    // sign-ins are explicitly rejected so that pool data is always tied to a
    // real, accountable identity.  Raw HTTP requests without a valid Firebase
    // Auth token are also blocked.
    match /pools/{poolId} {
      allow read, write: if request.auth != null
                         && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

  }
}
